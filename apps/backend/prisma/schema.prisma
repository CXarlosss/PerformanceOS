generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////////////////////////////
// 📌 ENUMS
////////////////////////////////////////////////////////////

enum Role {
  ADMIN
  ATHLETE
}

enum SessionStatus {
  PENDING
  COMPLETED
}

enum ProgramStatus {
  ACTIVE
  COMPLETED
}

enum InsightType {
  OVERLOAD
  UNDERTRAINING
  PLATEAU
  PROGRESSION
  RISK
}

enum InsightSeverity {
  LOW
  MEDIUM
  HIGH
}

enum AthleteLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum AthleteStatus {
  PENDING_INVITE
  ACTIVE
  ARCHIVED
}

enum BlockType {
  STRENGTH
  HYPERTROPHY
  POWER
  ENDURANCE
  ACCESSORY
}

////////////////////////////////////////////////////////////
// 👤 USERS
////////////////////////////////////////////////////////////

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  athleteProfile AthleteProfile?
  templates      ProgramTemplate[]
  athletes       AthleteProfile[]  @relation("CoachAthletes")

  @@index([role])
}

////////////////////////////////////////////////////////////
// 🧍 ATHLETE PROFILE
////////////////////////////////////////////////////////////

model AthleteProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  name      String
  level     AthleteLevel
  status    AthleteStatus @default(PENDING_INVITE)
  coachId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach            User?             @relation("CoachAthletes", fields: [coachId], references: [id])
  assignedPrograms AssignedProgram[]
  insights         Insight[]

  @@index([coachId])
}

////////////////////////////////////////////////////////////
// 🧠 INSIGHTS
////////////////////////////////////////////////////////////

model Insight {
  id String @id @default(uuid())

  athleteId String
  athlete   AthleteProfile @relation(fields: [athleteId], references: [id])

  type     InsightType
  severity InsightSeverity

  title   String
  message String

  relatedSessionId String?
  createdAt        DateTime @default(now())

  isRead Boolean @default(false)

  @@index([athleteId])
  @@index([createdAt])
}

////////////////////////////////////////////////////////////
// 🏋 GLOBAL EXERCISE CATALOG
////////////////////////////////////////////////////////////

model Exercise {
  id          String  @id @default(uuid())
  name        String
  category    String?
  muscleGroup String?
  isCompound  Boolean @default(false)

  createdAt DateTime @default(now())

  templateExercises  TemplateExercise[]
  assignedExercises  AssignedExercise[]

  @@index([name])
  @@index([muscleGroup])
}

////////////////////////////////////////////////////////////
// 📋 PROGRAM TEMPLATES (Blueprint)
////////////////////////////////////////////////////////////

model ProgramTemplate {
  id            String  @id @default(uuid())
  name          String
  description   String?
  durationWeeks Int

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  microcycles TemplateMicrocycle[]
  assignments AssignedProgram[]

  @@index([createdById])
}

////////////////////////////////////////////////////////////
// 📅 TEMPLATE MICROCYCLES
////////////////////////////////////////////////////////////

model TemplateMicrocycle {
  id         String @id @default(uuid())
  templateId String
  template   ProgramTemplate @relation(fields: [templateId], references: [id])

  weekNumber Int
  order      Int

  sessions TemplateSession[]

  @@index([templateId])
}

////////////////////////////////////////////////////////////
// 🏋 TEMPLATE SESSIONS
////////////////////////////////////////////////////////////

model TemplateSession {
  id           String @id @default(uuid())
  microcycleId String
  microcycle   TemplateMicrocycle @relation(fields: [microcycleId], references: [id])

  dayNumber Int
  order     Int
  title     String

  blocks TemplateBlock[]

  @@index([microcycleId])
}

////////////////////////////////////////////////////////////
// 🧱 TEMPLATE BLOCKS
////////////////////////////////////////////////////////////

model TemplateBlock {
  id        String @id @default(uuid())
  sessionId String
  session   TemplateSession @relation(fields: [sessionId], references: [id])

  type  BlockType
  order Int

  exercises TemplateExercise[]

  @@index([sessionId])
}

////////////////////////////////////////////////////////////
// 🏋 TEMPLATE EXERCISES
////////////////////////////////////////////////////////////

model TemplateExercise {
  id      String @id @default(uuid())
  blockId String
  block   TemplateBlock @relation(fields: [blockId], references: [id])

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  targetSets Int
  targetReps Int
  targetRpe  Float

  order Int

  @@index([blockId])
  @@index([exerciseId])
}

////////////////////////////////////////////////////////////
// 🔥 ASSIGNED PROGRAMS (Instance Layer)
////////////////////////////////////////////////////////////

model AssignedProgram {
  id         String @id @default(uuid())
  templateId String
  template   ProgramTemplate @relation(fields: [templateId], references: [id])

  athleteId String
  athlete   AthleteProfile @relation(fields: [athleteId], references: [id])

  startDate DateTime
  status    ProgramStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  microcycles     AssignedMicrocycle[]
  workoutSessions WorkoutSession[]

  @@index([athleteId])
  @@index([templateId])
}

////////////////////////////////////////////////////////////
// 📅 ASSIGNED MICROCYCLES
////////////////////////////////////////////////////////////

model AssignedMicrocycle {
  id                String @id @default(uuid())
  assignedProgramId String
  assignedProgram   AssignedProgram @relation(fields: [assignedProgramId], references: [id])

  weekNumber Int
  order      Int

  sessions AssignedSession[]

  @@index([assignedProgramId])
}

////////////////////////////////////////////////////////////
// 🏋 ASSIGNED SESSIONS
////////////////////////////////////////////////////////////

model AssignedSession {
  id           String @id @default(uuid())
  microcycleId String
  microcycle   AssignedMicrocycle @relation(fields: [microcycleId], references: [id])

  dayNumber Int
  order     Int
  title     String

  blocks          AssignedBlock[]
  workoutSessions WorkoutSession[]

  @@index([microcycleId])
}

////////////////////////////////////////////////////////////
// 🧱 ASSIGNED BLOCKS
////////////////////////////////////////////////////////////

model AssignedBlock {
  id        String @id @default(uuid())
  sessionId String
  session   AssignedSession @relation(fields: [sessionId], references: [id])

  type  BlockType
  order Int

  exercises AssignedExercise[]

  @@index([sessionId])
}

////////////////////////////////////////////////////////////
// 🏋 ASSIGNED EXERCISES
////////////////////////////////////////////////////////////

model AssignedExercise {
  id      String @id @default(uuid())
  blockId String
  block   AssignedBlock @relation(fields: [blockId], references: [id])

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  targetSets Int
  targetReps Int
  targetRpe  Float

  workoutSets WorkoutSet[]

  @@index([blockId])
  @@index([exerciseId])
}

////////////////////////////////////////////////////////////
// 🏋 WORKOUT SESSIONS (Execution Snapshot)
////////////////////////////////////////////////////////////

model WorkoutSession {
  id String @id @default(uuid())

  assignedProgramId String
  assignedProgram   AssignedProgram @relation(fields: [assignedProgramId], references: [id])

  assignedSessionId String
  assignedSession   AssignedSession @relation(fields: [assignedSessionId], references: [id])

  date   DateTime
  status SessionStatus

  // 🔥 Snapshot Metrics
  sessionVolume   Float?
  sessionFatigue  Float?
  sessionScore    Float?
  overloadFlag    Boolean?
  acwr            Float?    // Acute:Chronic Workload Ratio
  riskLevel       String?   // LOW | OPTIMAL | HIGH

  fatigueModelVersion Int?  // futura compatibilidad de fórmula

  completedAt DateTime?

  createdAt DateTime @default(now())

  sets WorkoutSet[]

  @@index([assignedProgramId])
  @@index([assignedSessionId])
  @@index([date])
}

////////////////////////////////////////////////////////////
// 🔢 WORKOUT SETS
////////////////////////////////////////////////////////////

model WorkoutSet {
  id String @id @default(uuid())

  workoutSessionId String
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id])

  assignedExerciseId String
  assignedExercise   AssignedExercise @relation(fields: [assignedExerciseId], references: [id])

  setNumber Int
  reps      Int
  load      Float
  rpe       Float
  isPR      Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([workoutSessionId])
  @@index([assignedExerciseId])
}